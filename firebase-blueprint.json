{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Event categories",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" }
      },
      "required": ["name"]
    },
    "Event": {
      "title": "Event",
      "description": "School events",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Event name" },
        "categoryId": { "type": "string", "description": "Reference to category" },
        "description": { "type": "string", "description": "Full description" },
        "imageUrl": { "type": "string", "description": "Event image URL" },
        "startDate": { "type": "string", "description": "Start date (YYYY-MM-DD)" },
        "startTime": { "type": "string", "description": "Start time (HH:MM)" },
        "endDate": { "type": "string", "description": "End date (YYYY-MM-DD)" },
        "endTime": { "type": "string", "description": "End time (HH:MM)" },
        "duration": { "type": "string", "description": "Event duration" },
        "restrictions": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["all", "years", "classes", "collaborators"] },
            "values": { "type": "array", "items": { "type": "string" } }
          }
        },
        "passwordProtected": { "type": "boolean" },
        "password": { "type": "string" },
        "formFields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "select"] },
              "options": { "type": "array", "items": { "type": "string" } },
              "required": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["name", "categoryId", "startDate", "startTime"]
    },
    "Student": {
      "title": "Student",
      "description": "Student database",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "surname": { "type": "string" },
        "class": { "type": "string" },
        "grade": { "type": "string" }
      },
      "required": ["name", "surname"]
    },
    "Registration": {
      "title": "Registration",
      "description": "Event registrations",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "studentId": { "type": "string" },
        "formData": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "studentId", "timestamp"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": { "schema": "Category", "description": "Event categories" },
    "/events/{eventId}": { "schema": "Event", "description": "School events" },
    "/students/{studentId}": { "schema": "Student", "description": "Student database" },
    "/registrations/{registrationId}": { "schema": "Registration", "description": "Event registrations" }
  }
}
